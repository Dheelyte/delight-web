# =========================================================================
# Copy to `.env` and fill values for local development.
# Production secrets live in Vercel and AWS Secrets Manager - never in git.
# =========================================================================

# --- Runtime ---------------------------------------------------------------
# One of: development | test | staging | production
ENVIRONMENT=

# --- Security --------------------------------------------------------------
# 32+ random bytes. Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# --- Database --------------------------------------------------------------
# asyncpg driver. The compose stack provisions this user/db.
DATABASE_URL=

# --- API <-> Web ----------------------------------------------------------
# Comma-separated list of origins allowed to call the API with credentials.
CORS_ALLOWED_ORIGINS=

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_API_URL=

# --- Email (Mailhog in dev; AWS SES in prod) -------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_FROM=

# --- Cloudinary ------------------------------------------------------------
# Sign up at cloudinary.com; use a separate cloud for dev vs prod.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Public alias of CLOUDINARY_CLOUD_NAME so the web app can build delivery URLs.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Seed admin (used by Stage 1 seed script) ------------------------------
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Public site (Stage 4) -------------------------------------------------
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_SITE_AUTHOR=

# --- On-demand ISR revalidation (Stage 4) ----------------------------------
# Shared secret between API (caller) and Next.js (receiver) at /api/revalidate.
REVALIDATE_SECRET=
# Where the API should POST revalidation calls; in prod set to the Vercel URL.
WEB_BASE_URL=
